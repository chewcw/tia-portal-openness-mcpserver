#!/bin/sh

. "$(dirname "$0")/_/husky.sh"

# Check if pushing any tags
TAG_REF=""
while read local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/tags/*)
      TAG_REF="$remote_ref"
      break
      ;;
  esac
done

if [ -z "$TAG_REF" ]; then
  exit 0
fi

# Extract tag name (refs/tags/v1.2.3 -> v1.2.3 -> 1.2.3)
TAG_NAME="${TAG_REF#refs/tags/}"
VERSION="${TAG_NAME#v}"

# Update cli/package.json version
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PACKAGE_JSON="$REPO_ROOT/cli/package.json"

if [ ! -f "$PACKAGE_JSON" ]; then
  echo "Warning: cli/package.json not found at $PACKAGE_JSON"
  exit 0
fi

# Use node to update version (cross-platform)
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('$PACKAGE_JSON', 'utf8'));
pkg.version = '$VERSION';
fs.writeFileSync('$PACKAGE_JSON', JSON.stringify(pkg, null, 2) + '\n');
console.log('Updated cli/package.json version to $VERSION');
"

# Stage the updated package.json
git add "$PACKAGE_JSON"

# Check if there are staged changes before committing
if ! git diff --cached --quiet; then
  git commit --amend --no-edit --no-verify
  echo "Amended HEAD commit with updated version"
fi
