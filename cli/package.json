{
  "name": "@bizarreaster/tia-portal-openness-mcpserver",
  "version": "0.0.2",
  "description": "CLI to install and manage TIA Portal MCP Server releases",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "bin": {
    "tia-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chewcw/tia-portal-openness-mcpserver.git"
  },
  "homepage": "https://github.com/chewcw/tia-portal-openness-mcpserver#readme",
  "bugs": {
    "url": "https://github.com/chewcw/tia-portal-openness-mcpserver/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
